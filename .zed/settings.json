{
    "languages": {
        "C++": {
            "format_on_save": "on",
            "formatter": {
                "external": {
                    "command": "clang-format",
                    "arguments": ["-style=file"],
                },
            },
        },
        "C": {
            "format_on_save": "on",
            "formatter": {
                "external": {
                    "command": "clang-format",
                    "arguments": ["-style=file"],
                },
            },
        },
    },
    "lsp": {
        "clangd": {
            "binary": {
                "arguments": [
                    "--background-index",
                    "--clang-tidy",
                    "--completion-style=detailed",
                    "--header-insertion=iwyu",
                    "--query-driver=**/*g++*",
                ],
            },
        },
    },
}
