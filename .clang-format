---
Language: Cpp
BasedOnStyle: LLVM
IndentWidth: 4
AccessModifierOffset: -4
BreakBeforeBraces: Custom
BraceWrapping:
    AfterClass: true
    AfterControlStatement: false
    AfterFunction: true
    AfterNamespace: false
    AfterStruct: true
    BeforeElse: false
AllowShortFunctionsOnASingleLine: None
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false
SortIncludes: true
IncludeBlocks: Regroup
IncludeCategories:
    - Regex: "^<[a-z0-9_]+>$"
      Priority: 2
    - Regex: "^<(boost|spdlog|gtest)/.*>"
      Priority: 3
    - Regex: '^<sodium\.h>'
      Priority: 3
    - Regex: "^<(core|crypto|network|protocol|domain|server|client)/.*>"
      Priority: 4
ColumnLimit: 100
PointerAlignment: Left
---
